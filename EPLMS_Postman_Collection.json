{
  "info": {
    "name": "EPLMS API",
    "description": "Employee Performance & Leave Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" },
    { "key": "token",    "value": "" },
    { "key": "emp_id",   "value": "1" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login as Employee",
          "event": [{ "listen": "test", "script": { "exec": [
            "const r = pm.response.json();",
            "pm.collectionVariables.set('token', r.token);",
            "pm.collectionVariables.set('emp_id', r.userId);"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"carol@eplms.com\",\n  \"password\": \"password\"\n}" }
          }
        },
        {
          "name": "Login as Manager",
          "event": [{ "listen": "test", "script": { "exec": [
            "const r = pm.response.json();",
            "pm.collectionVariables.set('token', r.token);"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"manager@eplms.com\",\n  \"password\": \"password\"\n}" }
          }
        },
        {
          "name": "Register Employee",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Eve New\",\n  \"email\": \"eve@eplms.com\",\n  \"password\": \"password\",\n  \"role\": \"EMPLOYEE\",\n  \"managerId\": 1\n}" }
          }
        }
      ]
    },
    {
      "name": "Leave",
      "item": [
        {
          "name": "Submit Leave (1 day - Auto Approved)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/leave/request",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"employeeId\": {{emp_id}},\n  \"leaveType\": \"ANNUAL\",\n  \"startDate\": \"2025-08-01\",\n  \"endDate\": \"2025-08-01\",\n  \"reason\": \"Personal errand\"\n}" }
          }
        },
        {
          "name": "Submit Leave (4 days - Team Lead)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/leave/request",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"employeeId\": {{emp_id}},\n  \"leaveType\": \"ANNUAL\",\n  \"startDate\": \"2025-08-05\",\n  \"endDate\": \"2025-08-08\",\n  \"reason\": \"Family vacation\"\n}" }
          }
        },
        {
          "name": "Submit Leave (7 days - HR Escalation)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/leave/request",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"employeeId\": {{emp_id}},\n  \"leaveType\": \"SICK\",\n  \"startDate\": \"2025-09-01\",\n  \"endDate\": \"2025-09-07\",\n  \"reason\": \"Medical procedure recovery\"\n}" }
          }
        },
        {
          "name": "Get Leave Balance",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/leave/balance/{{emp_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get My Leaves",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/leave/employee/{{emp_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Pending Leaves",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/leave/pending",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Approve Leave",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/leave/approve/2",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"action\": \"APPROVE\",\n  \"comment\": \"Approved by team lead\"\n}" }
          }
        },
        {
          "name": "Reject Leave",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/leave/approve/3",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"action\": \"REJECT\",\n  \"comment\": \"Insufficient staffing during this period\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Performance",
      "item": [
        {
          "name": "Create Goal",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/performance/goals",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"employeeId\": {{emp_id}},\n  \"title\": \"Complete AWS Solutions Architect certification\",\n  \"description\": \"Pass the SAA-C03 exam by Q3\",\n  \"targetDate\": \"2025-09-30\"\n}" }
          }
        },
        {
          "name": "Update Goal Status",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/performance/goals/1/status?status=COMPLETED",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Goals by Employee",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/performance/goals/employee/{{emp_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Submit Self Review",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/performance/review/self",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"employeeId\": {{emp_id}},\n  \"reviewYear\": 2025,\n  \"selfReview\": \"I delivered all assigned projects on time and mentored two junior developers.\",\n  \"selfRating\": 4.2\n}" }
          }
        },
        {
          "name": "Submit Manager Review",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/performance/review/manager",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"reviewId\": 1,\n  \"reviewerId\": 1,\n  \"managerReview\": \"Carol consistently exceeded expectations and showed strong leadership.\",\n  \"managerRating\": 4.5\n}" }
          }
        },
        {
          "name": "Get Reviews by Employee",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/performance/review/employee/{{emp_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get All Employees",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/users/employees",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Employee by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/users/employees/{{emp_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get All Managers",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/users/managers",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    }
  ]
}
